<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <!-- Видеоповерхность во весь экран -->
    <SurfaceView
        android:id="@+id/surface"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Слой панели управления поверх видео (с полной адаптацией под темы) -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Верхний тулбар (адаптивная тема!) -->
        <LinearLayout
            android:id="@+id/layout_top_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="14dp"
            android:background="@color/bg_secondary">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_back"
                android:padding="9dp"
                android:background="@drawable/bg_ripple_circle"
                app:tint="@color/icon_accent" />

            <TextView
                android:id="@+id/tv_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="middle" />

            <!-- Кнопка смены ориентации экрана (Поворот, ИСПРАВЛЕНА на адаптивный цвет!) -->
            <ImageView
                android:id="@+id/btn_rotate"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_video_rotate"
                android:padding="9dp"
                android:background="@drawable/bg_ripple_circle"
                app:tint="@color/icon_accent"
                android:layout_marginEnd="6dp" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Центральный блок кнопок управления (Адаптивные иконки для идеального соответствия теме) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="16dp">

            <!-- Кнопка перемотки назад (-10 секунд) -->
            <ImageView
                android:id="@+id/btn_rew"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_video_rewind"
                android:padding="12dp"
                android:background="@drawable/bg_ripple_circle"
                app:tint="@android:color/white" />

            <!-- Предыдущее видео -->
            <ImageView
                android:id="@+id/btn_prev"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_player_prev"
                android:padding="14dp"
                android:background="@drawable/bg_ripple_circle"
                app:tint="@android:color/white"
                android:layout_marginStart="16dp" />

            <!-- Воспроизведение / Пауза (FAB) -->
            <ImageView
                android:id="@+id/btn_play"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_play"
                android:padding="18dp"
                android:background="@drawable/bg_fab_gold"
                app:tint="@color/text_on_gold"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp" />

            <!-- Следующее видео -->
            <ImageView
                android:id="@+id/btn_next"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:src="@drawable/ic_player_next"
                android:padding="14dp"
                android:background="@drawable/bg_ripple_circle"
                app:tint="@android:color/white"
                android:layout_marginEnd="16dp" />

            <!-- Кнопка перемотки вперед (+10 секунд) -->
            <ImageView
                android:id="@+id/btn_ff"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_video_fast_forward"
                android:padding="12dp"
                android:background="@drawable/bg_ripple_circle"
                app:tint="@android:color/white" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Нижний блок SeekBar, времени и ЛЕНТЫ МИНИАТЮР заметки -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp"
            android:paddingBottom="16dp"
            android:background="@color/bg_secondary">

            <!-- Лента миниатюр видеозаписей (высота увеличена до 64dp, чтобы исключить обрезание!) -->
            <LinearLayout
                android:id="@+id/layout_bottom_strip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:text="Видеозаписи заметки"
                    android:textColor="@color/gold_primary"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="6dp" />

                <!-- Высота установлена в 64dp, соответствуя высоте вложенных карточек! -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_thumbnails"
                    android:layout_width="match_parent"
                    android:layout_height="64dp"
                    android:orientation="horizontal"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:clipToPadding="false"
                    android:scrollbars="none" />
            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_bar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:progressTint="@color/gold_primary"
                android:thumbTint="@color/gold_primary"
                android:progressBackgroundTint="@color/bg_tertiary" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <TextView
                    android:id="@+id/tv_current"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="00:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />

                <TextView
                    android:id="@+id/tv_total"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

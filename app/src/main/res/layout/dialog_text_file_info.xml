<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottomsheet"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- Ручка шторки -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_sheet_handle"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Информация о файле"
        android:textColor="@color/gold_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="18dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_settings_section"
        android:padding="16dp">

        <!-- Имя файла -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Имя файла:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_stat_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Размер файла -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Размер:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_stat_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Строк -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Кол-во строк:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_stat_lines"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Слов -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Кол-во слов:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_stat_words"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Символов -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="8dp">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Всего символов:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_stat_chars"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp" />

        <!-- Символов без пробелов -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Без пробелов:"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
            <TextView
                android:id="@+id/tv_stat_chars_no_spaces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btn_close_info"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Закрыть"
        android:textColor="@color/text_on_gold"
        android:background="@drawable/bg_button_gold"
        android:layout_marginTop="16dp"
        android:textStyle="bold" />
</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottomsheet"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- Ручка шторки -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:background="@drawable/bg_sheet_handle"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Очередь воспроизведения"
        android:textColor="@color/gold_primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="14dp" />

    <!-- Список треков -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_playlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_settings_section"
        android:padding="8dp" />

    <Button
        android:id="@+id/btn_close_playlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Закрыть"
        android:textColor="@color/text_on_gold"
        android:background="@drawable/bg_button_gold"
        android:layout_marginTop="16dp"
        android:textStyle="bold" />
</LinearLayout>

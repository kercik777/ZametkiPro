<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <include layout="@layout/include_top_bar" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp"
                android:background="@drawable/bg_settings_section">

                <!-- Иконка убрана по запросу. -->

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/backup_title"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/backup_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingMultiplier="1.35" />
            </LinearLayout>

            <TextView style="@style/Text.GoldAccent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/backup_auto_title"
                android:textSize="12sp"
                android:layout_marginTop="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_section">

                <LinearLayout android:id="@+id/row_auto_backup" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:src="@drawable/ic_restore" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_auto_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/backup_auto_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_auto_backup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:showText="false"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <View style="@style/SettingsDiv" />

                <LinearLayout android:id="@+id/row_auto_folder" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:src="@drawable/ic_file" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_auto_folder_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />
                        <TextView
                            android:id="@+id/tv_auto_folder_path"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/backup_auto_folder_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <ImageView style="@style/SettingsArrow" />
                </LinearLayout>
            </LinearLayout>

            <TextView style="@style/Text.GoldAccent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_data"
                android:textSize="12sp"
                android:layout_marginTop="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:background="@drawable/bg_settings_section">

                <LinearLayout android:id="@+id/row_export" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:src="@drawable/ic_export" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_export_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/backup_export_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <ImageView style="@style/SettingsArrow" />
                </LinearLayout>

                <View style="@style/SettingsDiv" />

                <LinearLayout android:id="@+id/row_import" style="@style/SettingsRow">
                    <ImageView style="@style/SettingsIcon" android:src="@drawable/ic_import" />
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/backup_import_title"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/backup_import_desc"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>
                    <ImageView style="@style/SettingsArrow" />
                </LinearLayout>
            </LinearLayout>

            <TextView style="@style/Text.GoldAccent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/backup_warning_title"
                android:textSize="12sp"
                android:layout_marginTop="22dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:padding="18dp"
                android:background="@drawable/bg_settings_section"
                android:gravity="top|center_vertical">

                <!-- Иконка "Важно" убрана по запросу. -->

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/backup_warning_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:lineSpacingMultiplier="1.35" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="32dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>

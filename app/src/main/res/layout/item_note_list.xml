<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="6dp"
    android:layout_marginEnd="6dp"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_card_note_fill"
    android:elevation="2dp"
    android:foreground="@drawable/bg_ripple_rounded">

    <LinearLayout
        android:id="@+id/content_layer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/attachments_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/v_color_bar"
                    android:layout_width="3dp"
                    android:layout_height="22dp"
                    android:layout_marginEnd="10dp"
                    android:background="@color/gold_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageView android:id="@+id/iv_pin"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="8dp"
                    android:src="@drawable/ic_pin_outline" app:tint="@color/gold_primary"
                    android:visibility="gone" />
                <ImageView android:id="@+id/iv_fav"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_star_outline" app:tint="@color/gold_primary"
                    android:visibility="gone" />
                <ImageView android:id="@+id/iv_lock"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_lock" app:tint="@color/gold_primary"
                    android:visibility="gone" />
                <ImageView android:id="@+id/iv_reminder"
                    android:layout_width="16dp" android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_alarm" app:tint="@color/gold_primary"
                    android:visibility="gone" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_preview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.3"
                android:maxLines="3"
                android:ellipsize="end" />

            <LinearLayout
                android:id="@+id/checklist_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="vertical"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <View
                    android:id="@+id/v_category_dot"
                    android:layout_width="9dp"
                    android:layout_height="9dp"
                    android:layout_marginEnd="6dp"
                    android:background="@drawable/bg_category_dot"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/tv_meta"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/gold_primary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <FrameLayout
        android:id="@+id/swipe_layer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:clickable="false"
        android:focusable="false">

        <View
            android:id="@+id/v_swipe_bg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent" />

        <ImageView
            android:id="@+id/iv_swipe_start"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="18dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_swipe_end"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="18dp"
            android:visibility="gone" />
    </FrameLayout>

        <View
        android:id="@+id/v_card_border"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_card_note_stroke" />

<View
        android:id="@+id/v_selection"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_selection_overlay"
        android:visibility="gone" />
</FrameLayout>

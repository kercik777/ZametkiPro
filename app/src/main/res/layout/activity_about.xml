<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <include layout="@layout/include_top_bar" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <FrameLayout
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_logo_gradient_subtle">

                <ImageView
                    android:id="@+id/iv_logo"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo" />
            </FrameLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/app_name"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold"
                android:letterSpacing="0.04" />

            <TextView
                android:id="@+id/tv_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="@string/about_version_label"
                android:textColor="@color/gold_primary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:gravity="center"
                android:text="@string/about_description"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:lineSpacingMultiplier="1.5"
                android:paddingStart="14dp"
                android:paddingEnd="14dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="28dp"
                android:padding="22dp"
                android:background="@drawable/bg_settings_section">

                <TextView
                    style="@style/Text.GoldAccent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_features_title"
                    android:textSize="13sp"
                    android:layout_marginBottom="14dp" />

                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_1"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_2"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_3"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_4"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_5"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_6"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_7"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_8"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
                <TextView style="@style/Text.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/about_feature_9"
                    android:textSize="14sp"
                    android:paddingTop="3dp"
                    android:paddingBottom="3dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:layout_marginBottom="20dp"
                android:text="@string/about_made_with"
                android:textColor="@color/gold_primary"
                android:textSize="13sp"
                android:textStyle="italic"
                android:letterSpacing="0.04" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>

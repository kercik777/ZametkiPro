<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="14dp"
    android:paddingBottom="20dp"
    android:gravity="center_horizontal">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_marginBottom="22dp"
        android:background="@drawable/bg_sheet_handle" />

    <FrameLayout
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:background="@drawable/bg_logo_gradient_subtle">
        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_info"
            app:tint="@color/gold_primary" />
    </FrameLayout>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="19sp"
        android:textStyle="bold"
        android:letterSpacing="0.01" />

    <TextView
        android:id="@+id/tv_message"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:gravity="center"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:lineSpacingMultiplier="1.4" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="22dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:text="@string/cancel"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_ghost"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/btn_confirm"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="OK"
            android:textColor="@color/text_on_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:letterSpacing="0.04"
            android:background="@drawable/bg_button_gold"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>

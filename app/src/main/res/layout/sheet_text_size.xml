<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="10dp"
    android:paddingBottom="18dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_sheet_handle" />

    <TextView
        android:id="@+id/tv_title"
        style="@style/SheetSubtitle"
        android:text="@string/text_size_title" />

    <TextView
        android:id="@+id/tv_size_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="22dp"
        android:layout_marginEnd="22dp"
        android:layout_marginTop="8dp"
        android:text="16"
        android:textColor="@color/gold_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <SeekBar
        android:id="@+id/seek_text_size"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:max="15"
        android:progress="6"
        android:progressTint="@color/gold_primary"
        android:thumbTint="@color/gold_primary" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:gravity="end"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp">

        <TextView
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:gravity="center"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:text="@string/reset"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:background="@drawable/bg_ripple_rounded"
            android:singleLine="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="@string/cancel"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:background="@drawable/bg_ripple_rounded"
            android:singleLine="true" />

        <TextView
            android:id="@+id/btn_apply"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:minWidth="0dp"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:text="@string/save"
            android:textColor="@color/text_on_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_gold"
            android:singleLine="true" />
    </LinearLayout>
</LinearLayout>

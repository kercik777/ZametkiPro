<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Базовая тема — использует @color/ ресурсы (светлые/тёмные в зависимости от квалификатора) -->
    <style name="Theme.ZametkiPro" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorPrimaryVariant">@color/gold_dark</item>
        <item name="colorOnPrimary">@color/text_on_gold</item>
        <item name="colorSecondary">@color/gold_light</item>
        <item name="colorSecondaryVariant">@color/gold_primary</item>
        <item name="colorOnSecondary">@color/text_on_gold</item>

        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>

        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/nav_bar</item>
        <item name="android:windowLightStatusBar">@bool/light_status_bar</item>
        <item name="android:windowLightNavigationBar">@bool/light_nav_bar</item>

        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorTertiary">@color/text_tertiary</item>
        <item name="android:textColorHint">@color/text_tertiary</item>

        <item name="android:fontFamily">sans-serif</item>

        <item name="materialAlertDialogTheme">@style/ThemeOverlay.ZametkiPro.Dialog</item>
        <item name="bottomSheetDialogTheme">@style/ThemeOverlay.ZametkiPro.BottomSheet</item>
        <item name="snackbarStyle">@style/Widget.ZametkiPro.Snackbar</item>
        <item name="snackbarTextViewStyle">@style/Widget.ZametkiPro.Snackbar.TextView</item>
        <item name="snackbarButtonStyle">@style/Widget.ZametkiPro.Snackbar.Button</item>
    </style>

    <style name="Theme.ZametkiPro.NoActionBar" parent="Theme.ZametkiPro" />

    <!-- Splash тема -->
    <style name="Theme.ZametkiPro.Splash" parent="Theme.ZametkiPro.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
    </style>

    <!-- Диалоги -->
    <style name="ThemeOverlay.ZametkiPro.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/gold_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:background">@drawable/bg_dialog</item>
        <item name="materialAlertDialogTitleTextStyle">@style/Dialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/Dialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/Dialog.Button.Positive</item>
        <item name="buttonBarNegativeButtonStyle">@style/Dialog.Button.Negative</item>
        <item name="buttonBarNeutralButtonStyle">@style/Dialog.Button.Neutral</item>
    </style>

    <style name="Dialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/gold_light</item>
        <item name="android:textSize">19sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Dialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="Dialog.Button.Positive" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/gold_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Dialog.Button.Negative" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Dialog.Button.Neutral" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- BottomSheet -->
    <style name="ThemeOverlay.ZametkiPro.BottomSheet" parent="ThemeOverlay.MaterialComponents.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.ZametkiPro.BottomSheet</item>
    </style>

    <style name="Widget.ZametkiPro.BottomSheet" parent="Widget.MaterialComponents.BottomSheet.Modal">
        <item name="android:background">@drawable/bg_bottomsheet</item>
        <item name="behavior_peekHeight">auto</item>
    </style>

    <!-- Snackbar -->
    <style name="Widget.ZametkiPro.Snackbar" parent="Widget.MaterialComponents.Snackbar">
        <item name="android:background">@drawable/bg_snackbar</item>
        <item name="actionTextColorAlpha">1.0</item>
    </style>

    <style name="Widget.ZametkiPro.Snackbar.TextView" parent="Widget.MaterialComponents.Snackbar.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Widget.ZametkiPro.Snackbar.Button" parent="Widget.MaterialComponents.Button.TextButton.Snackbar">
        <item name="android:textColor">@color/gold_light</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- ===== Базовый текстовый стиль (родитель для Text.*) ===== -->
    <style name="Text" parent="android:Widget.TextView">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- ===== Текстовые стили ===== -->
    <style name="Text.Display" parent="Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="Text.Headline" parent="Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Title" parent="Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Text.Subtitle" parent="Text">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <style name="Text.Body" parent="Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">15sp</item>
        <item name="android:lineSpacingMultiplier">1.3</item>
    </style>

    <style name="Text.Caption" parent="Text">
        <item name="android:textColor">@color/text_tertiary</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="Text.GoldAccent" parent="Text">
        <item name="android:textColor">@color/gold_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>
</resources>
